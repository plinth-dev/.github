{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    "group:monorepos",
    "group:recommended",
    ":pinDevDependencies"
  ],
  "schedule": ["before 6am on Monday"],
  "timezone": "Etc/UTC",
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "prHourlyLimit": 4,
  "prConcurrentLimit": 8,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["dependencies", "security"],
    "schedule": ["at any time"]
  },
  "packageRules": [
    {
      "description": "Group all non-major upgrades together once a week.",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "all non-major",
      "groupSlug": "all-non-major"
    },
    {
      "description": "Major version bumps get their own PR for review.",
      "matchUpdateTypes": ["major"],
      "groupName": null
    },
    {
      "description": "Critical CVE fixes — never wait for the weekly window.",
      "matchPackagePatterns": ["*"],
      "matchCurrentVersion": "!@",
      "vulnerabilityAlerts": {
        "schedule": ["at any time"],
        "prCreation": "immediate"
      }
    }
  ]
}
